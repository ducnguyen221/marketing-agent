# Sao chép thành .env rồi điền. .env đã bị gitignore — KHÔNG commit.
# Mỗi instance dùng bộ biến riêng theo hậu tố <INSTANCE_SLUG> viết hoa, gạch dưới.

# ── YouTube (Data API v3 + Analytics API) ───────────────────────────────────
# Cần scope: https://www.googleapis.com/auth/youtube
#            https://www.googleapis.com/auth/yt-analytics.readonly   ← để đọc số liệu
YT_CLIENT_SECRET__DUCNGUYEN_AI=C:\path\to\youtube_client_secret.json
YT_TOKEN_PATH__DUCNGUYEN_AI=C:\path\to\youtube_token.json

# ── Facebook Page (Graph API) ───────────────────────────────────────────────
# Page token cần quyền: pages_manage_posts, pages_read_engagement, read_insights
FB_PAGE_ID__DUCNGUYEN_AI=
FB_PAGE_TOKEN__DUCNGUYEN_AI=

# ── Thông báo (tuỳ chọn) ────────────────────────────────────────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=
